@@ -32,6 +32,33 @@ static gboolean meta_wayland_seat_handle_event_internal (MetaWaylandSeat    *sea
 #define CAPABILITY_ENABLED(prev, cur, capability) ((cur & (capability)) && !(prev & (capability)))
 #define CAPABILITY_DISABLED(prev, cur, capability) ((prev & (capability)) && !(cur & (capability)))
 
+/* --- Annotations fork: optional wl_pointer target rewrite (tablet unchanged) --- */
+static gboolean fork_annotation_pointer_passthrough = FALSE;
+
+static MetaWaylandSurface *
+fork_annotation_resolve_pointer_surface (MetaWaylandSeat      *seat,
+                                         MetaWaylandSurface   *surface,
+                                         ClutterFocus         *focus)
+{
+  if (!fork_annotation_pointer_passthrough)
+    return surface;
+
+  /* TODO: Descend scene / alternate pick so wl_pointer targets the client under
+   * Shell chrome. Extension overlay is usually not a MetaWaylandSurface; see
+   * mutter-fork/docs/input-trace.md */
+  (void) seat;
+  (void) focus;
+  return surface;
+}
+
+void
+meta_fork_annotation_seat_set_pointer_passthrough (MetaWaylandSeat *seat,
+                                                 gboolean passthrough)
+{
+  g_return_if_fail (seat != NULL);
+  fork_annotation_pointer_passthrough = passthrough;
+}
+
 static void
 unbind_resource (struct wl_resource *resource)
 {
@@ -270,7 +297,12 @@ default_focus (MetaWaylandEventHandler *handler,
        CLUTTER_INPUT_CAPABILITY_TOUCHPAD |
        CLUTTER_INPUT_CAPABILITY_TRACKBALL |
        CLUTTER_INPUT_CAPABILITY_TRACKPOINT))
-    meta_wayland_pointer_focus_surface (seat->pointer, surface);
+    {
+      MetaWaylandSurface *pointer_surface =
+        fork_annotation_resolve_pointer_surface (seat, surface, focus);
+
+      meta_wayland_pointer_focus_surface (seat->pointer, pointer_surface);
+    }
 }
 
