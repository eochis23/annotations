@@ -1311,3 +1311,14 @@ meta_wayland_compositor_sync_focus (MetaWaylandCompositor *compositor)
   meta_wayland_compositor_update_focus (compositor,
                                         display ? display->focus_window : NULL);
 }
+
+void
+meta_fork_annotation_set_pointer_passthrough (MetaWaylandCompositor *compositor,
+                                              gboolean passthrough)
+{
+  g_return_if_fail (META_IS_WAYLAND_COMPOSITOR (compositor));
+  if (!compositor->seat)
+    return;
+
+  meta_fork_annotation_seat_set_pointer_passthrough (compositor->seat, passthrough);
+}
