+#include <gio/gio.h>
+
 #include <clutter/clutter.h>
 #include <gjs/gjs.h>
 #include <meta/display.h>
 #include <meta/meta-plugin.h>
+#include <meta/meta-wayland-compositor.h>
 #include <meta/util.h>
 #include <mtk/mtk.h>
 
@@ -61,6 +64,41 @@ struct _GnomeShellPlugin
 
 G_DEFINE_TYPE (GnomeShellPlugin, gnome_shell_plugin, META_TYPE_PLUGIN)
 
+static GSettings *annotation_fork_shell_settings;
+static gulong annotation_fork_settings_handler;
+
+static void
+annotation_fork_sync_pointer_passthrough (GnomeShellPlugin *shell_plugin)
+{
+  MetaDisplay *display;
+  MetaContext *context;
+  MetaWaylandCompositor *wayland_compositor;
+  gboolean enable;
+
+  if (!annotation_fork_shell_settings)
+    return;
+
+  display = meta_plugin_get_display (META_PLUGIN (shell_plugin));
+  context = meta_display_get_context (display);
+  wayland_compositor = meta_context_get_wayland_compositor (context);
+  if (!wayland_compositor)
+    return;
+
+  enable = g_settings_get_boolean (annotation_fork_shell_settings,
+                                   "annotation-pointer-passthrough");
+  meta_fork_annotation_set_pointer_passthrough (wayland_compositor, enable);
+}
+
+static void
+annotation_fork_pointer_passthrough_changed (GnomeShellPlugin *shell_plugin,
+                                             GSettings         *settings,
+                                             const char        *key)
+{
+  (void) settings;
+  (void) key;
+  annotation_fork_sync_pointer_passthrough (shell_plugin);
+}
+
 static void
 gnome_shell_plugin_start (MetaPlugin *plugin)
 {
@@ -68,6 +106,19 @@ gnome_shell_plugin_start (MetaPlugin *plugin)
 
   shell_plugin->global = shell_global_get ();
   _shell_global_set_plugin (shell_plugin->global, META_PLUGIN (shell_plugin));
+
+  /* Annotations fork: follow org.gnome.shell annotation-pointer-passthrough (see docs/shell-integration.md). */
+  if (!annotation_fork_shell_settings)
+    {
+      annotation_fork_shell_settings = g_settings_new ("org.gnome.shell");
+      annotation_fork_settings_handler =
+        g_signal_connect_swapped (annotation_fork_shell_settings,
+                                    "changed::annotation-pointer-passthrough",
+                                    G_CALLBACK (annotation_fork_pointer_passthrough_changed),
+                                    shell_plugin);
+    }
+
+  annotation_fork_sync_pointer_passthrough (shell_plugin);
 }
 
